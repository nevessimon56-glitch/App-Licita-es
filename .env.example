# Chave da API Google Gemini (obrigatória)
GEMINI_API_KEY=AIza...

# Proteção por senha (opcional — se definida, bloqueia o app e as APIs)
SITE_PASSWORD=sua-senha-secreta

# Segredo para assinar o cookie de sessão (recomendado em produção)
# Se omitido, usa SITE_PASSWORD como fallback
# AUTH_SECRET=uma-string-longa-e-aleatoria

# Modelo para ANÁLISE — padrão: gemini-2.5-flash (melhor qualidade)
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash

# Modelo rápido (opcional, se quiser priorizar velocidade):
# GEMINI_ANALYSIS_MODEL=gemini-2.5-flash-lite

# Modelo para CHAT — padrão: gemini-2.5-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Atalho: define os dois (opcional, sobrescreve os acima se único)
# GEMINI_MODEL=gemini-2.5-flash-lite
